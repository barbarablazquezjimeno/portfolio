---
import Button from '@/components/Button.astro';
import Chip from '@/components/Chip.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  overline?: string;
  date?: Date;
  cover?: string;
  viewCaseLabel?: string;
  coverAlt?: string;
  cta?: string;
  problem?: string;
  solution?: string;
  tools?: string[];
  skills?: string[];
}


const { 
  href, 
  title, 
  description, 
  overline,
  date, 
  cover, 
  viewCaseLabel = "Acceder al detalle del proyecto",
  coverAlt,
  cta,
  problem,
  solution,
  tools = [],
  skills = []
} = Astro.props;

const metaText = overline ?? title ?? (date ? String(date.getFullYear()) : '');
const linkName = `${viewCaseLabel}: ${title}`;
const imageAlt = cover ? (coverAlt ?? '') : '';
const dateTime = date ? date.toISOString().slice(0, 10) : undefined;
const displayedSkills = skills.slice(0, 4);

function publicAssetSrc(path: string): string {
  if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('//')) return path;
  const base = import.meta.env.BASE_URL || '/';
  const normalized = base.endsWith('/') ? base : `${base}/`;
  const trimmed = path.startsWith('/') ? path.slice(1) : path;
  return `${normalized}${trimmed}`;
}

const coverSrc = cover ? publicAssetSrc(cover) : undefined;
---

<article class="card-default">
  <div class="card-default__header">
    <div class="card-default__media">
      {
        coverSrc ? (
          <img
            src={coverSrc}
            alt={imageAlt}
            loading="lazy"
            width="160"
            height="100"
            decoding="async"
          />
        ) : (
          <div class="card-default__placeholder" role="img" aria-hidden="true"></div>
        )
      }
    </div>

    <div class="card-default__content">
      {metaText && (
        <p class="card-default__meta">
          {overline || !dateTime ? metaText : <time datetime={dateTime}>{metaText}</time>}
        </p>
      )}

      <p class="card-default__desc">{description}</p>

      <div class="card-default__footer">
        <Button variant="secondary" href={href} icon="→" aria-label={linkName} text={cta}>{!cta && viewCaseLabel}</Button>
      </div>

      {displayedSkills.length > 0 && (
        <div class="card-default__skills">
          {displayedSkills.map((skill) => (
            <Chip label={skill} />
          ))}
        </div>
      )}
    </div>
  </div>
</article>

<style>
  .card-default {
    background: transparent;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    text-align: left;
  }

  .card-default__header {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr);
    gap: var(--space-md);
    align-items: stretch;
  }

  .card-default__media {
    width: 160px;
    height: 100%;
    min-height: 100%;
    max-height: none;
    overflow: hidden;
    background: var(--accent-soft);
    flex-shrink: 0;
    justify-self: start;
    grid-row: 1 / span 1;
  }

  .card-default__media img {
    width: 100%;
    height: 100%;
    min-height: 100%;
    object-fit: cover;
    display: block;
  }

  .card-default__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--accent-soft), transparent 60%);
  }

  .card-default__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
  }

  .card-default__meta {
    margin: 0 0 var(--space-xs);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .card-default__desc {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.5;
    color: var(--text);
  }

  .card-default__skills {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    align-items: center;
    gap: 0;
    overflow-x: auto;
  }

  .card-default__footer {
    padding-top: var(--space-md);
  }

  .card-default__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .card-default__section-title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .card-default__section-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .card-default__footer :global(.btn--secondary) {
    padding: 0;
  }

  @media (max-width: 720px) {
    .card-default__header {
      grid-template-columns: 1fr;
    }

    .card-default__media {
      justify-self: start;
    }
  }

  .card-default__tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .card-default__tool {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    background: var(--border);
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
