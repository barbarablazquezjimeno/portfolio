---
import Button from '@/components/Button.astro';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  cover?: string;
  viewCaseLabel: string;
  coverAlt?: string;
  problem?: string;
  solution?: string;
  tools?: string[];
  skills?: string[];
}

const { 
  href, 
  title, 
  description, 
  date, 
  cover, 
  viewCaseLabel, 
  coverAlt,
  problem,
  solution,
  tools = [],
  skills = []
} = Astro.props;

const year = date.getFullYear();
const linkName = `${viewCaseLabel}: ${title}`;
const imageAlt = cover ? (coverAlt ?? '') : '';
const displayedSkills = skills.slice(0, 4);

function publicAssetSrc(path: string): string {
  if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('//')) return path;
  const base = import.meta.env.BASE_URL || '/';
  const normalized = base.endsWith('/') ? base : `${base}/`;
  const trimmed = path.startsWith('/') ? path.slice(1) : path;
  return `${normalized}${trimmed}`;
}

const coverSrc = cover ? publicAssetSrc(cover) : undefined;
---

<article class="card-default">
  <div class="card-default__header">
    <div class="card-default__media">
      {
        coverSrc ? (
          <img
            src={coverSrc}
            alt={imageAlt}
            loading="lazy"
            width="160"
            height="100"
            decoding="async"
          />
        ) : (
          <div class="card-default__placeholder" role="img" aria-hidden="true"></div>
        )
      }
    </div>
    <div class="card-default__content">
      <div class="card-default__top">
        <div>
          <p class="card-default__meta">
            <time datetime={date.toISOString().slice(0, 10)}>{year}</time>
          </p>
          <h3 class="card-default__title">{title}</h3>
          <p class="card-default__desc">{description}</p>
        </div>
        <Button variant="secondary" href={href} icon="→" aria-label={linkName}>{viewCaseLabel}</Button>
      </div>
      {displayedSkills.length > 0 && (
        <div class="card-default__skills">
          {displayedSkills.map((skill) => (
            <span class="card-default__chip">{skill}</span>
          ))}
        </div>
      )}
    </div>
  </div>

  {(problem || solution || tools.length > 0) && (
    <details class="card-default__details">
      <summary class="card-default__summary">Detalles del proyecto</summary>
      <div class="card-default__details-content">
        {problem && (
          <div class="card-default__section">
            <h4 class="card-default__section-title">Problema</h4>
            <p class="card-default__section-text">{problem}</p>
          </div>
        )}
        {solution && (
          <div class="card-default__section">
            <h4 class="card-default__section-title">Solución</h4>
            <p class="card-default__section-text">{solution}</p>
          </div>
        )}
        {tools.length > 0 && (
          <div class="card-default__section">
            <h4 class="card-default__section-title">Herramientas</h4>
            <div class="card-default__tools">
              {tools.map((tool) => (
                <span class="card-default__tool">{tool}</span>
              ))}
            </div>
          </div>
        )}
      </div>
    </details>
  )}
</article>

<style>
  .card-default {
    border-radius: var(--radius);
    background: var(--bg-elevated);
    overflow: hidden;
  }

  .card-default__header {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-md);
    padding: var(--space-md);
  }

  .card-default__media {
    width: 160px;
    height: 100px;
    border-radius: 8px;
    overflow: hidden;
    background: var(--accent-soft);
    flex-shrink: 0;
  }

  .card-default__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-default__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--accent-soft), transparent 60%);
  }

  .card-default__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .card-default__top {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .card-default__meta {
    margin: 0 0 var(--space-xs);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .card-default__title {
    margin: 0 0 var(--space-xs);
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .card-default__desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .card-default__skills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .card-default__chip {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: var(--accent-soft);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
  }

  .card-default__details {
    border-top: 1px solid var(--border);
    padding: var(--space-md);
    cursor: pointer;
  }

  .card-default__summary {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 600;
    color: var(--text);
    padding-left: 1.5rem;
    position: relative;
  }

  .card-default__summary::before {
    content: '▶';
    position: absolute;
    left: 0;
    transition: transform 0.2s ease;
    font-size: 0.8rem;
    color: var(--accent);
  }

  .card-default__details[open] .card-default__summary::before {
    transform: rotate(90deg);
  }

  .card-default__details-content {
    padding-top: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .card-default__section {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .card-default__section-title {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text);
  }

  .card-default__section-text {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .card-default__tools {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .card-default__tool {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    background: var(--border);
    border-radius: 6px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
