---
import { marked } from 'marked';

interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary" | "ghost";
  children?: string | undefined;
  icon?: string;
  class?: string;
  id?: string;
  'aria-label'?: string;
  title?: string;
  text?: string; // Optional markdown string rendered as inline HTML
}

const { 
  href, 
  type = "button", 
  variant = "primary", 
  children,
  icon, 
  class: customClass, 
  id,
  'aria-label': ariaLabel,
  title: titleAttr,
  text,
  ...rest 
} = Astro.props;
const Component = href ? "a" : "button";
const classNames = `btn btn--${variant} ${customClass || ''}`.trim();
const buttonTitle = titleAttr || (text ? text : (typeof children === 'string' ? children : ''));
const buttonAriaLabel = ariaLabel || (text ? text : (typeof children === 'string' ? children : ''));
const buttonText = text ? marked.parseInline(text) : undefined;
---

<Component 
  class={classNames} 
  id={id}
  href={href} 
  type={href ? undefined : type}
  title={buttonTitle}
  aria-label={buttonAriaLabel}
  {...rest}
>
  <span class="btn__text">
    {buttonText ? <Fragment set:html={buttonText} /> : <slot /> }
  </span>
  {icon && <span class="btn__icon">{icon}</span>}
</Component>

<script>
  // Magnetic Button Effect
  function initMagneticButtons() {
    const buttons = document.querySelectorAll('.btn--primary, .btn--ghost');
    
    buttons.forEach((btn) => {
      if (!(btn instanceof HTMLElement)) return;
      
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        // Move button slightly towards cursor
        btn.style.transform = `translate(${x * 0.2}px, ${y * 0.2}px)`;
      });
      
      btn.addEventListener('mouseleave', () => {
        // Reset position with a spring-like feel (handled by CSS transition)
        btn.style.transform = '';
      });
    });
  }

  initMagneticButtons();
  document.addEventListener('astro:after-swap', initMagneticButtons);
</script>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: var(--tap-min);
    padding: 0.75rem 1.5rem;
    border-radius: var(--radius);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid transparent;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
  }

  /* Primary variant: filled */
  .btn--primary {
    position: relative;
    overflow: hidden;
    background: var(--text);
    color: var(--bg);
    border-color: var(--text);
  }

  .btn--primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, color-mix(in oklab, var(--bg) 25%, transparent), transparent);
    transform: translateX(-100%);
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .btn--primary:hover::before {
    transform: translateX(100%);
  }

  .btn--primary:hover {
    background: transparent;
    color: var(--text);
    box-shadow: 0 8px 24px color-mix(in oklab, var(--text) 15%, transparent);
  }

  .btn--primary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Secondary variant: text only, semibold, underlined on hover, no border */
  .btn--secondary {
    padding: 0.35rem 0;
    min-height: auto;
    color: var(--text);
    border: none;
    background: transparent;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }

  .btn--secondary:hover {
    color: var(--text-muted);
  }

  .btn--secondary:hover .btn__text {
    text-decoration: underline;
    text-decoration-offset: 3px;
  }

  .btn--secondary:hover .btn__icon {
    text-decoration: none;
  }

  .btn--secondary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Ghost variant: border, no fill, text color */
  .btn--ghost {
    border-color: var(--border);
    color: var(--text);
    background: transparent;
    backdrop-filter: blur(8px);
  }

  .btn--ghost:hover {
    border-color: var(--text);
    color: var(--text);
    background: color-mix(in oklab, var(--text) 4%, transparent);
    box-shadow: 0 8px 24px color-mix(in oklab, var(--text) 10%, transparent);
  }

  .btn--ghost:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .btn__icon {
    display: inline-flex;
    align-items: center;
    font-weight: 700;
  }

  .btn__text {
    display: inline;
  }
</style>
