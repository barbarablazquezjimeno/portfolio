---
interface Props {
  href?: string;
  type?: "button" | "submit" | "reset";
  variant?: "primary" | "secondary";
  children?: any;
  icon?: string;
  class?: string;
  id?: string;
  'aria-label'?: string;
  title?: string;
  [key: string]: any;
}

const { 
  href, 
  type = "button", 
  variant = "primary", 
  children = "Ver mis proyectos",
  icon, 
  class: customClass, 
  id,
  'aria-label': ariaLabel,
  title: titleAttr,
  ...rest 
} = Astro.props;
const Component = href ? "a" : "button";
const classNames = `btn btn--${variant} ${customClass || ''}`.trim();
const buttonTitle = titleAttr || (typeof children === 'string' ? children : 'Ver mis proyectos');
const buttonAriaLabel = ariaLabel || (typeof children === 'string' ? children : 'Ver mis proyectos');
---

<Component 
  class={classNames} 
  id={id}
  href={href} 
  type={href ? undefined : type}
  title={buttonTitle}
  aria-label={buttonAriaLabel}
  {...rest}
>
  <span class="btn__text">{children}</span>
  {icon && <span class="btn__icon">{icon}</span>}
</Component>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 1rem;
  }

  /* Primary variant: 2px border, no fill, black text */
  .btn--primary {
    padding: 0.65rem 1.25rem;
    min-height: var(--tap-min);
    color: var(--text);
    border: 2px solid var(--text);
    background: transparent;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
  }

  .btn--primary:hover {
    background-color: var(--text);
    color: var(--bg);
  }

  .btn--primary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Secondary variant: text only, semibold, underlined on hover, no border */
  .btn--secondary {
    padding: 0.35rem 0;
    min-height: auto;
    color: var(--text);
    border: none;
    background: transparent;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
  }

  .btn--secondary:hover {
    color: var(--text-muted);
  }

  .btn--secondary:hover .btn__text {
    text-decoration: underline;
    text-decoration-offset: 3px;
  }

  .btn--secondary:hover .btn__icon {
    text-decoration: none;
  }

  .btn--secondary:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .btn__icon {
    display: inline-flex;
    align-items: center;
    font-weight: 700;
  }

  .btn__text {
    display: inline;
  }
</style>
