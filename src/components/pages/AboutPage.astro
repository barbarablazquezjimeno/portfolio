---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { ui, type Locale } from '@/i18n/ui';
import { Download, Clock, Briefcase } from 'lucide-astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = ui[lang];

const experiences = [
  {
    id: "softtek",
    company: "Softtek",
    period: "3 años 2 meses",
    details: "Jornada completa · Madrid · En remoto",
    subRoles: [
      {
        title: "Real Madrid - Product designer",
        period: "mar. 2024 - actualidad · 2 años 2 meses",
        skills: ["Auditorías WCAG 2.1", "Diseño Inclusivo", "Design Systems", "Design Tokens", "IA Tools"],
        achievements: [
          "Análisis y auditorías de accesibilidad (WCAG 2.1) en web y apps móviles.",
          "Creación y mantenimiento del Design System para mobile con Design Tokens.",
          "Liderazgo en fases de Concept, Research y Diseño con metodologías centradas en el usuario.",
          "Facilitación de sesiones de Brainstorming y co-creación con stakeholders.",
          "Aplicación de herramientas IA: Perplexity, Google AI studio, Copilot, Cursor, Figma Make."
        ]
      },
      {
        title: "Inditex - Product designer",
        period: "mar. 2023 - mar. 2024 · 1 año 1 mes",
        skills: ["UX/UI Design", "Mobile & Wearables", "User Research"],
        achievements: [
          "Diseño de interfaces UX/UI para plataformas internas y clientes.",
          "Ejecución de procesos de investigación con usuarios (User Research).",
          "Realización de entrevistas reales con usuarios finales.",
          "Optimización de experiencias para dispositivos mobile y wearables."
        ]
      }
    ]
  },
  {
    id: "rovi",
    company: "ROVI Pharmaceutical Company",
    role: "UX/UI Product designer",
    period: "may. 2021 - mar. 2023 · 1 año 11 meses",
    details: "Jornada completa · Madrid",
    skills: ["Prototipado", "Arquitectura de Información", "Usability Testing", "Análisis de KPIs"],
    achievements: [
      "Análisis de información cualitativa/cuantitativa y detección de ineficiencias (As Is).",
      "Diseño del Digital Journey: requisitos funcionales, flujos y arquitectura.",
      "Diseño UI, Copywriting y definición de identidad visual de procesos.",
      "Seguimiento de implementación y gestión de expectativas con stakeholders.",
      "Testeo en fase beta y mentorización de usuarios.",
      "Iteración constante y elaboración de KPIs para mejora continua."
    ]
  },
  {
    id: "viaja",
    company: "Viaja, Disfruta y Ayuda",
    role: "UX/UI Designer",
    period: "nov. 2020 - jun. 2021 · 8 meses",
    details: "Jornada parcial · Madrid",
    skills: ["User Research", "Branding", "Card Sorting", "User Personas"],
    achievements: [
      "Diseño de contenido (UX) e interfaces web (e-commerce Wordpress).",
      "Investigación: card sorting, user personas y flujos de usuario.",
      "Identidad corporativa, packaging, branding y marketing digital.",
      "Apoyo en creación de infografías, iconografía y edición visual."
    ]
  },
  {
    id: "buscoextra",
    company: "BuscoExtra - ETT Hostelería Digital",
    role: "Técnico Generalista RRHH (Startup)",
    period: "ene. 2019 - mar. 2020 · 1 año 3 meses",
    details: "Madrid",
    skills: ["Brainstorming", "User Interviews", "Testing"],
    achievements: [
      "UX Research: Apoyo en brainstorming, entrevistas y testing para mejora de la app."
    ]
  }
];
---

<BaseLayout lang={lang} title={`${t.about.title} — ${t.metaTitle}`}>
  <div class="shell">
    <header class="about-header">
      <h1 class="page-title">{t.about.title}</h1>
      <a href="/cv.pdf" download class="download-link">
        <span>Descargar CV</span>
        <Download size={18} />
      </a>
    </header>

    <div class="timeline">
      {experiences.map((exp, index) => (
        <article class="exp-block">
          <div class="exp-sidebar">
            <div class="exp-company-icon">
              <Briefcase size={20} />
            </div>
            <div class="exp-line"></div>
          </div>
          
          <div class="exp-content">
            <div class="exp-header">
              <div class="exp-main-info">
                <h2 class="exp-company-name">{exp.company}</h2>
                <p class="exp-total-period">{exp.period}</p>
              </div>
              <div class="exp-meta">
                <Clock size={14} />
                <span>{exp.details}</span>
              </div>
            </div>

            {exp.subRoles ? (
              <div class="sub-roles">
                {exp.subRoles.map((sub) => (
                  <div class="sub-role-item">
                    <h3 class="sub-role-title">{sub.title}</h3>
                    <p class="sub-role-period">{sub.period}</p>
                    
                    <div class="skills-tags">
                      {sub.skills.map(skill => <span class="tag">{skill}</span>)}
                    </div>

                    <ul class="achievements-list">
                      {sub.achievements.map(ach => <li>{ach}</li>)}
                    </ul>
                  </div>
                ))}
              </div>
            ) : (
              <div class="role-details">
                <h3 class="sub-role-title">{exp.role}</h3>
                <div class="skills-tags">
                  {exp.skills?.map(skill => <span class="tag">{skill}</span>)}
                </div>
                <ul class="achievements-list">
                  {exp.achievements?.map(ach => <li>{ach}</li>)}
                </ul>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .about-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
  }

  .download-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .download-link:hover {
    color: var(--text);
  }

  /* Timeline Styles */
  .timeline {
    position: relative;
    max-width: 54rem;
    margin-bottom: var(--space-3xl);
  }

  .exp-block {
    display: flex;
    gap: var(--space-lg);
    margin-bottom: 0;
  }

  .exp-sidebar {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .exp-company-icon {
    width: 44px;
    height: 44px;
    background: var(--text);
    color: var(--bg);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    flex-shrink: 0;
  }

  .exp-line {
    flex-grow: 1;
    width: 2px;
    background: var(--border);
    margin: 8px 0;
  }

  .exp-block:last-child .exp-line {
    display: none;
  }

  .exp-content {
    padding-bottom: var(--space-2xl);
    flex-grow: 1;
  }

  .exp-header {
    margin-bottom: var(--space-lg);
  }

  .exp-company-name {
    font-size: 1.75rem;
    font-weight: 600;
    margin: 0;
  }

  .exp-total-period {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .exp-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  /* Sub roles / Details */
  .sub-roles {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .sub-role-item {
    position: relative;
    padding-left: var(--space-md);
    border-left: 2px solid var(--border-light);
  }

  .sub-role-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
  }

  .sub-role-period {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: var(--space-sm) 0 var(--space-md);
  }

  .tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    padding: 0.25rem 0.6rem;
    background: var(--bg-offset);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-muted);
  }

  .achievements-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .achievements-list li {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--text-muted);
    position: relative;
    padding-left: 1.25rem;
  }

  .achievements-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6rem;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--border);
  }

  @media (max-width: 640px) {
    .exp-sidebar {
      display: none;
    }
    .exp-content {
      padding-bottom: var(--space-xl);
    }
  }
</style>