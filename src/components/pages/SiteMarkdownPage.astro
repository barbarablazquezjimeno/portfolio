---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { render, type CollectionEntry } from 'astro:content';
import { ui, type Locale } from '@/i18n/ui';

interface Props {
  lang: Locale;
  page: CollectionEntry<'sitePages'>;
}

const { lang, page } = Astro.props;
const t = ui[lang];
const { Content } = await render(page);
---

<BaseLayout lang={lang} title={`${page.data.title} — ${t.metaTitle}`} description={page.data.description}>
  <div class="shell article">
    <h1 class="page-title">{page.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </div>
</BaseLayout>

<style>
  .article {
    max-width: 48rem;
  }

  .page-title {
    margin: 0 0 var(--space-xl);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
  }
</style>
