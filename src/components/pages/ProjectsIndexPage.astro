---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectCardDefault from '@/components/ProjectCardDefault.astro';
import Button from '@/components/Button.astro';
import { ui, pathForLocale, projectDetailPath, type Locale } from '@/i18n/ui';
import { listProjects, projectSlugFromId } from '@/lib/projects';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = ui[lang];
const items = await listProjects(lang);
---

<BaseLayout lang={lang} title={`${t.projects.title} — ${t.metaTitle}`}>
  <div class="shell">
    <header class="page-head">
      <h1 class="page-title">{t.projects.title}</h1>
      <div class="back-wrapper">
        <Button variant="secondary" href={pathForLocale(lang, 'home')}>{t.projects.back}</Button>
      </div>
    </header>
    <div class="grid">
      {
        items.map((p) => {
          const slug = projectSlugFromId(p.id, lang);
          return (
            <ProjectCardDefault
              href={projectDetailPath(lang, slug)}
              title={p.data.title}
              description={p.data.description}
              overline={p.data.overline}
              date={p.data.date}
              cover={p.data.cover}
              coverAlt={p.data.coverAlt}
              cta={p.data.cta}
              viewCaseLabel={t.a11y.viewCase}
              problem={p.data.problem}
              solution={p.data.solution}
              tools={p.data.tools}
              skills={p.data.skills}
            />
          );
        })
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page-head {
    max-width: 100%;
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .back-wrapper {
    margin-top: var(--space-md);
  }

  .page-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-lg);
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
