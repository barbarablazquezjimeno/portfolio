---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import ProjectCardPreview from '@/components/ProjectCardPreview.astro';
import { ui, pathForLocale, projectDetailPath, type Locale } from '@/i18n/ui';
import { listProjects, projectSlugFromId } from '@/lib/projects';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = ui[lang];
const featured = await listProjects(lang, { featuredOnly: true });
const showcase = featured.length > 0 ? featured : (await listProjects(lang)).slice(0, 3);
---

<BaseLayout lang={lang} title={t.metaTitle} description={t.metaDescription}>
  <div class="shell">
    <section class="hero" aria-labelledby="hero-title">
      <p class="hero__kicker">{t.home.kicker}</p>
      <h1 id="hero-title" class="hero__title">{t.home.headline}</h1>
      <p class="hero__sub">{t.home.sub}</p>
      <div class="hero__actions">
        <Button variant="primary" href={pathForLocale(lang, 'projects')}>
          {t.home.ctaProjects}
        </Button>
      </div>
    </section>

    <section class="section" aria-labelledby="feat-title">
      <div class="section__head">
        <h2 id="feat-title" class="section__title">{t.home.moreTitle}</h2>
      </div>
      <div class="grid">
        {
          showcase.map((p) => {
            const slug = projectSlugFromId(p.id, lang);
            return (
              <ProjectCardPreview
                href={projectDetailPath(lang, slug)}
                title={p.data.title}
                description={p.data.description}
                date={p.data.date}
                cover={p.data.cover}
                coverAlt={p.data.coverAlt}
                viewCaseLabel={t.a11y.viewCase}
              />
            );
          })
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-xl) 0 var(--space-2xl);
    max-width: 40rem;
  }

  .hero__kicker {
    margin: 0 0 var(--space-sm);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero__title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.5vw, 2.85rem);
    font-weight: 600;
    line-height: 1.12;
  }

  .hero__sub {
    margin: 0 0 var(--space-lg);
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 36rem;
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .section {
    margin-top: var(--space-lg);
  }

  .section__head {
    margin-bottom: var(--space-lg);
  }

  .section__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }
</style>
