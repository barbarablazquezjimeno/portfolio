---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.astro';
import ProjectCardDefault from '@/components/ProjectCardDefault.astro';
import { ui, pathForLocale, projectDetailPath, type Locale } from '@/i18n/ui';
import { listProjects, projectSlugFromId } from '@/lib/projects';
import { Download, Clock } from 'lucide-astro';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = ui[lang];
const featured = await listProjects(lang, { featuredOnly: true });
const showcase = featured.length > 0 ? featured : (await listProjects(lang)).slice(0, 3);

const experiences = [
  {
    id: "softtek",
    company: "Softtek",
    period: "3 años 2 meses",
    details: "Jornada completa · Madrid · En remoto",
    subRoles: [
      {
        title: "Real Madrid - Product designer",
        logo: "/images/logos/real-madrid.svg",
        period: "mar. 2024 - actualidad · 2 años 2 meses",
        skills: ["Auditorías WCAG 2.1", "Diseño Inclusivo", "Design Systems", "Design Tokens", "IA Tools"],
        achievements: [
          "Análisis y auditorías de accesibilidad (WCAG 2.1) en web y apps móviles.",
          "Creación y mantenimiento del Design System para mobile con Design Tokens.",
          "Liderazgo en fases de Concept, Research y Diseño con metodologías centradas en el usuario.",
          "Facilitación de sesiones de Brainstorming y co-creación con stakeholders.",
          "Aplicación de herramientas IA: Perplexity, Google AI studio, Copilot, Cursor, Figma Make."
        ]
      },
      {
        title: "Inditex - Product designer",
        logo: "/images/logos/inditex.svg",
        period: "mar. 2023 - mar. 2024 · 1 año 1 mes",
        skills: ["UX/UI Design", "Mobile & Wearables", "User Research"],
        achievements: [
          "Diseño de interfaces UX/UI para plataformas internas y clientes.",
          "Ejecución de procesos de investigación con usuarios (User Research).",
          "Realización de entrevistas reales con usuarios finales.",
          "Optimización de experiencias para dispositivos mobile y wearables."
        ]
      }
    ]
  },
  {
    id: "rovi",
    company: "ROVI Pharmaceutical Company",
    role: "UX/UI Product designer",
    period: "may. 2021 - mar. 2023 · 1 año 11 meses",
    details: "Jornada completa · Madrid",
    skills: ["Prototipado", "Arquitectura de Información", "Usability Testing", "Análisis de KPIs"],
    achievements: [
      "Análisis de información cualitativa/cuantitativa y detección de ineficiencias (As Is).",
      "Diseño del Digital Journey: requisitos funcionales, flujos y arquitectura.",
      "Diseño UI, Copywriting y definición de identidad visual de procesos.",
      "Seguimiento de implementación y gestión de expectativas con stakeholders.",
      "Testeo en fase beta y mentorización de usuarios.",
      "Iteración constante y elaboración de KPIs para mejora continua."
    ]
  }
];
---


<BaseLayout lang={lang} title={t.metaTitle} description={t.metaDescription}>
  <main>
    <section id="hero" class="hero reveal" aria-labelledby="hero-title">
      <div class="shell hero-container">
        <div class="hero__content">
          <p class="hero__kicker">{t.home.kicker}</p>
          <h1 id="hero-title" class="hero__title">{t.home.headline}</h1>
          <p class="hero__sub">{t.home.sub}</p>
          <div class="hero__actions">
            <Button variant="primary" href="#proyectos">
              {t.home.ctaProjects}
            </Button>
          </div>
        </div>
        <div class="hero__illustration" aria-hidden="true">
          <div class="illustration-placeholder">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
              <path fill="var(--accent-soft)" d="M44.7,-76.4C58.8,-69.2,71.8,-59.1,79.6,-46.2C87.4,-33.3,90,-16.6,89.1,-0.51C88.2,15.6,83.7,31.2,75.3,44.7C66.9,58.3,54.7,69.8,40.6,77.4C26.5,85,10.6,88.7,-4.8,97C-20.2,105.3,-35.1,118.2,-48.7,118.5C-62.3,118.8,-74.6,106.5,-83.4,92.5C-92.2,78.5,-97.5,62.8,-100.8,46.9C-104.1,31,-105.4,15.5,-103.1,0.5C-100.8,-14.5,-94.9,-29.1,-87.3,-43.3C-79.7,-57.5,-70.4,-71.3,-57.7,-79.3C-45,-87.3,-29,-89.5,-14.1,-87.4C0.8,-85.3,15.6,-78.9,30.6,-83.6C45.6,-88.3,60.8,-104.1,44.7,-76.4Z" transform="translate(100 100)" />
              <circle cx="100" cy="100" r="40" fill="var(--accent)" opacity="0.2" />
              <rect x="70" y="70" width="60" height="60" rx="10" fill="var(--accent)" opacity="0.1" />
            </svg>
          </div>
        </div>
      </div>
    </section>

    <section id="proyectos" class="projects-section reveal" aria-labelledby="projects-title">
      <div class="shell projects-showcase">
        <h2 id="projects-title" class="section-title">{t.projects.title}</h2>
        <div class="grid">
          { (await listProjects(lang)).map((p) => {
            const slug = projectSlugFromId(p.id, lang);
            return (
              <ProjectCardDefault
                href={projectDetailPath(lang, slug)}
                title={p.data.title}
                description={p.data.description}
                overline={p.data.overline}
                date={p.data.date}
                cover={p.data.cover}
                coverAlt={p.data.coverAlt}
                cta={p.data.cta}
                viewCaseLabel={t.a11y.viewCase}
                problem={p.data.problem}
                solution={p.data.solution}
                tools={p.data.tools}
                skills={p.data.skills}
              />
            );
          }) }
        </div>
      </div>
    </section>

    <section id="sobre-mi" class="about-section reveal" aria-labelledby="about-title">
      <div class="shell">
        <h2 id="about-title" class="section-title">{t.about.title}</h2>
        
        <div class="timeline">
          {experiences.map((exp, index) => (
            <article class="exp-block">
              <div class="exp-sidebar">
                <div class="exp-dot"></div>
                <div class="exp-line"></div>
              </div>
              
              {exp.logo && (
                <div class="exp-logo">
                  <img src={exp.logo} alt={exp.company} class="logo-img" />
                </div>
              )}
              
              <div class="exp-content">
                <div class="exp-header">
                  <div class="exp-main-info">
                    <h3 class="exp-company-name">{exp.company}</h3>
                    <p class="exp-total-period">{exp.period}</p>
                  </div>
                  <div class="exp-meta">
                    <Clock size={14} />
                    <span>{exp.details}</span>
                  </div>
                </div>

                {exp.subRoles ? (
                  <div class="sub-roles">
                    {exp.subRoles.map((sub) => (
                      <div class="sub-role-item">
                        <div class="sub-role-header">
                          {sub.logo && <img src={sub.logo} alt={sub.title} class="sub-logo-img" />}
                          <div>
                            <h4 class="sub-role-title">{sub.title}</h4>
                            <p class="sub-role-period">{sub.period}</p>
                          </div>
                        </div>
                        
                        <div class="skills-tags">
                          {sub.skills.map(skill => <span class="tag">{skill}</span>)}
                        </div>

                        <ul class="achievements-list">
                          {sub.achievements.map(ach => <li>{ach}</li>)}
                        </ul>
                      </div>
                    ))}
                  </div>
                ) : (
                  <div class="role-details">
                    <h4 class="sub-role-title">{exp.role}</h4>
                    <div class="skills-tags">
                      {exp.skills?.map(skill => <span class="tag">{skill}</span>)}
                    </div>
                    <ul class="achievements-list">
                      {exp.achievements?.map(ach => <li>{ach}</li>)}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="contacto" class="contact-section reveal" aria-labelledby="contact-title">
      <div class="shell">
        <h2 id="contact-title" class="section-title">{t.contact.title}</h2>
        <p>{t.contact.description}</p>
        <!-- Aquí puedes añadir tu formulario o datos de contacto -->
      </div>
    </section>
  </main>

     <!-- CTA minimalista e interactivo -->
      <section class="cta-minimal" aria-labelledby="cta-minimal-title">
        <div class="cta-minimal__inner">
          <div>
            <h3 id="cta-minimal-title" class="cta-minimal__title">¿Quieres ver más?</h3>
            <p class="cta-minimal__lead">Explora más proyectos en mi Behance.</p>
          </div>
          <div class="cta-minimal__controls">
            <Button
              variant="primary"
              href="https://www.behance.net/tu-perfil"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Ver más proyectos en Behance (abre en nueva pestaña)"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" aria-hidden="true" style="vertical-align:middle;margin-right:8px">
                <rect width="24" height="24" fill="none" />
                <text x="0" y="16" font-family="Inter, system-ui, -apple-system, 'Helvetica Neue', Arial" font-weight="700" font-size="14" fill="currentColor">Bē</text>
              </svg>
              Ver más
            </Button>
          </div>
        <div id="cta-extra" class="cta-minimal__extra" hidden aria-live="polite"></div>
       </section>
  </main>

  <style>
    .hero-container {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: calc(100vh - 120px);
    text-align: left;
  }

  .hero {
    padding: var(--space-xl) 0;
    width: 100%;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2xl);
  }

  .hero__content {
    flex: 1;
    max-width: 38rem;
  }

  .hero__kicker {
    margin: 0 0 var(--space-sm);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hero__title {
    margin: 0 0 var(--space-md);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 600;
    line-height: 1.1;
  }

  .hero__sub {
    margin: 0 0 var(--space-lg);
    font-size: 1.15rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .hero__actions {
    display: flex;
    justify-content: flex-start;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero__illustration {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    align-items: center;
    max-width: 400px;
  }

  .illustration-placeholder {
    width: 100%;
    max-width: 400px;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.1));
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .hero.reveal--active .illustration-placeholder {
    /* Mantenemos una posición estática o un ligero ajuste al activarse */
    transform: scale(1.05);
  }

  @media (max-width: 900px) {
    .hero {
      flex-direction: column;
      text-align: center;
      gap: var(--space-xl);
    }

    .hero__illustration {
      justify-content: center;
      order: -1; /* Muestra la ilustración arriba en móvil */
    }

    .hero__actions {
      justify-content: center;
    }
  }

  /* Estilos para secciones con colores diferentes */
  .hero {
    background-color: var(--bg);
  }

  .about-section {
    background-color: #f0f4f3; /* Verde muy suave */
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }

  .projects-section {
    background-color: #f7f7f7; /* Gris neutro suave */
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
  }

  .contact-section {
    background-color: #fffaf0; /* Crema suave */
    padding: var(--space-2xl) 0;
    border-top: 1px solid var(--border);
    text-align: center;
  }

  /* Animaciones */
  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .reveal--active {
    opacity: 1;
    transform: translateY(0);
  }

  .hero__kicker {
    opacity: 0;
  }

  .hero.reveal--active .hero__kicker {
    animation: fadeInDown 0.8s ease-out forwards;
  }

  .hero.reveal--active .hero__title {
    animation: fadeInUp 0.8s ease-out 0.2s forwards;
  }

  .hero.reveal--active .hero__sub {
    animation: fadeInUp 0.8s ease-out 0.4s forwards;
  }

  .hero.reveal--active .hero__actions {
    animation: fadeInUp 0.8s ease-out 0.6s forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fadeInDown {
    from {
      opacity: 0;
      transform: translateY(-20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .section-title {
    margin: 0 0 var(--space-lg);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.2;
  }

  /* Timeline / Experiencias */
  .timeline {
    display: flex;
    flex-direction: column;
  }

  .exp-block {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-md);
    padding: var(--space-xl) 0;
    background: transparent !important;
    border: none !important;
    border-bottom: 1px solid var(--border) !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    align-items: start;
  }

  .exp-block:last-child {
    border-bottom: none;
  }

  .exp-logo {
    width: 60px;
    height: 60px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-elevated);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    flex-shrink: 0;
    padding: var(--space-sm);
  }

  .logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .sub-logo-img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    flex-shrink: 0;
    margin-right: var(--space-sm);
  }

  .sub-role-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-sm)e-xl) 0;
    background: transparent !important;
    border: none !important;
    border-bottom: 1px solid var(--border) !important;
    border-radius: 0 !important;
    box-shadow: none !important;
  }

  .exp-block:last-child {
    border-bottom: none;
  }

  .exp-sidebar {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6px; /* Ajuste para alinear con el texto */
  }

  .exp-dot {
    width: 12px;
    height: 12px;
    background: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
    z-index: 2;
  }

  .exp-line {
    flex: 1;
    width: 2px;
    background: var(--border);
    margin-top: 4px;
    margin-bottom: -24px; /* Extiende la línea hacia el siguiente bloque */
  }

  .exp-block:last-child .exp-line {
    background: linear-gradient(to bottom, var(--border), transparent);
  }

  .exp-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-md);
  }

  .exp-company-name {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
  }

  .exp-total-period {
    margin: var(--space-xs) 0 0;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .exp-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-size: 0.85rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .sub-roles {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }

  .sub-role-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .sub-role-title {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .sub-role-period {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .skills-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .tag {
    display: inline-block;
    padding: 0.35rem 0.65rem;
    background: var(--accent-soft);
    color: var(--accent);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
  }

  .achievements-list {
    margin: 0;
    padding-left: var(--space-md);
    list-style: disc;
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .achievements-list li {
    margin-bottom: var(--space-xs);
  }

  .role-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  /* Grid de proyectos */
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-lg);
  }

  /* Estilos de contacto */
  .contact-section {
    text-align: center;
  }

  .contact-section p {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin: var(--space-lg) 0;
  }

  /* CTA minimalista */
  .cta-minimal {
    background: var(--bg-elevated);
    padding: var(--space-2xl) 0;
    margin-top: var(--space-2xl);
  }

  .cta-minimal__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .cta-minimal__title {
    margin: 0 0 var(--space-sm);
    font-size: 1.5rem;
    font-weight: 600;
  }

  .cta-minimal__lead {
    margin: 0;
    color: var(--text-muted);
    font-size: 1rem;
  }

  @media (max-width: 720px) {
    .exp-block {
      grid-template-columns: 1fr;
    }

    .exp-sidebar {
      flex-direction: row;
    }

    .exp-line {
      display: none;
    }

    .exp-header {
      flex-direction: column;
    }

    .grid {
      grid-template-columns: 1fr;
    }

    .cta-minimal__inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('reveal--active');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.reveal').forEach(section => {
    observer.observe(section);
  });
</script>
</BaseLayout>

