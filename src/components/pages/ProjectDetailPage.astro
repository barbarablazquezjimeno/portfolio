---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { render, type CollectionEntry } from 'astro:content';
import { ui, pathForLocale, projectDetailPath, otherLocale, type Locale } from '@/i18n/ui';
import { findProjectTranslation, projectSlugFromId } from '@/lib/projects';

interface Props {
  lang: Locale;
  entry: CollectionEntry<'projects'>;
}

const { lang, entry } = Astro.props;
const { Content } = await render(entry);
const t = ui[lang];
const other = otherLocale(lang);
const alt = await findProjectTranslation(entry.data.pairSlug, other);
const altSlug = alt ? projectSlugFromId(alt.id, other) : null;
const altLabel = lang === 'es' ? t.a11y.viewCaseInEnglish : t.a11y.viewCaseInSpanish;
---

<BaseLayout lang={lang} title={`${entry.data.title} — ${t.metaTitle}`} description={entry.data.description}>
  <article class="shell article">
    <header class="article__head">
      <a class="back" href={pathForLocale(lang, 'projects')} aria-label={t.a11y.backToProjects}>
        ← {t.nav.projects}
      </a>
      <p class="article__meta">
        <time datetime={entry.data.date.toISOString().slice(0, 10)}>{entry.data.date.getFullYear()}</time>
      </p>
      <h1 class="article__title">{entry.data.title}</h1>
      <p class="article__lede">{entry.data.description}</p>
      {
        alt && altSlug && (
          <p class="article__alt">
            <a href={projectDetailPath(other, altSlug)} hreflang={other} lang={other}>
              {altLabel}
            </a>
          </p>
        )
      }
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    max-width: 48rem;
  }

  .article__head {
    margin-bottom: var(--space-xl);
  }

  .back {
    display: inline-flex;
    align-items: center;
    min-height: var(--tap-min);
    margin-bottom: var(--space-md);
    font-weight: 600;
    text-decoration: none;
    color: var(--text-muted);
  }

  .back:hover {
    color: var(--accent);
  }

  .article__meta {
    margin: 0 0 var(--space-xs);
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .article__title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3vw, 2.35rem);
    font-weight: 600;
    line-height: 1.15;
  }

  .article__lede {
    margin: 0;
    font-size: 1.1rem;
    color: var(--text-muted);
  }

  .article__alt {
    margin: var(--space-md) 0 0;
    font-size: 0.95rem;
  }
</style>
