---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CaseSection from '@/components/CaseSection.astro';
import type { Locale } from '@/i18n/ui';
import { ui } from '@/i18n/ui';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: Locale;
  entry: CollectionEntry<'projects'>;
}

const { lang, entry } = Astro.props;
const t = ui[lang];
---

<BaseLayout lang={lang} title={`${entry.data.title} — ${t.metaTitle}`} description={entry.data.description}>
  <div id="project-detail" class="project-detail-page">
    <CaseSection lang={lang} entry={entry} />
  </div>
</BaseLayout>

<style>
  .project-detail-page {
    min-height: 50vh;
    margin-top: calc(-1 * var(--space-lg));
  }
</style>
