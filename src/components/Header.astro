---
import { ui, pathForLocale, otherLocale, type Locale } from '@/i18n/ui';
import { stripBasePath, withBasePath, swapLocaleInPath } from '@/lib/localePaths';

interface Props {
  lang: Locale;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = ui[lang];
const baseUrl = import.meta.env.BASE_URL || '/';
const relative = stripBasePath(currentPath, baseUrl);
const other = otherLocale(lang);
const langHref = withBasePath(swapLocaleInPath(relative, lang, other), baseUrl);
const langSwitchLabel = other === 'en' ? t.a11y.switchToEnglish : t.a11y.switchToSpanish;

function linkFor(page: 'home' | 'projects' | 'about' | 'contact') {
  return pathForLocale(lang, page);
}

const nav = [
  { id: 'top', href: linkFor('home'), label: t.nav.home },
  { id: 'projects', href: linkFor('projects'), label: t.nav.projects },
  { id: 'about', href: linkFor('about'), label: t.nav.about },
  { id: 'contact', href: linkFor('contact'), label: t.nav.contact },
];

function active(_href: string) {
  return false;
}
---

<header class="header">
  <div class="shell header__shell">
    <div class="header__bar">
      <a class="logo" href={linkFor('home')} aria-label={t.a11y.logoToHome}>
        <span aria-hidden="true">{t.nav.logo}</span>
      </a>

      <nav id="site-nav" class="site-nav" aria-label={t.a11y.navPrimary}>
        <ul class="site-nav__list">
          {
            nav.map((item) => (
              <li class="site-nav__item">
                <a
                  href={item.href}
                  class="site-nav__link"
                  data-nav-section={item.id}
                  aria-current={undefined}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="header__end">
        <a class="lang" href={langHref} hreflang={other} lang={other} aria-label={langSwitchLabel}>
          <span aria-hidden="true">{other === 'es' ? t.lang.es : t.lang.en}</span>
        </a>
        <button
          type="button"
          class="menu-btn"
          id="nav-toggle"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label={t.a11y.openMenu}
          data-open-label={t.a11y.openMenu}
          data-close-label={t.a11y.closeMenu}
        >
          <span class="menu-btn__hamburger" aria-hidden="true">
            <span class="menu-btn__bar"></span>
            <span class="menu-btn__bar"></span>
            <span class="menu-btn__bar"></span>
          </span>
          <span class="menu-btn__text">{t.a11y.menuToggleVisible}</span>
        </button>
      </div>
    </div>
  </div>
</header>

<script>
function initHeaderScripts() {
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  if (toggle && nav) {
    const openL = toggle.getAttribute('data-open-label') ?? '';
    const closeL = toggle.getAttribute('data-close-label') ?? '';
    const mq = window.matchMedia('(min-width: 48rem)');

    function setOpen(open) {
      nav.classList.toggle('site-nav--open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? closeL : openL);
    }

    function closeIfMobile() {
      if (!mq.matches) setOpen(false);
    }

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        toggle.focus();
      }
    });

    mq.addEventListener('change', (e) => {
      if (e.matches) {
        nav.classList.remove('site-nav--open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', openL);
      }
    });

    nav.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', (e) => {
        closeIfMobile();
        
        // Implement JS smooth scroll for anchor links so we don't need CSS scroll-behavior: smooth
        // which breaks Astro View Transitions back navigation.
        const href = link.getAttribute('href');
        if (href && href.includes('#')) {
          const id = href.split('#')[1];
          const target = document.getElementById(id);
          if (target) {
            // Only prevent default if we are already on the same page
            if (window.location.pathname === href.split('#')[0] || href.startsWith('#')) {
              e.preventDefault();
              target.scrollIntoView({ behavior: 'smooth' });
              
              // Update URL hash manually
              if (window.history.pushState) {
                const url = new URL(window.location.href);
                url.hash = id === 'top' ? '' : id;
                window.history.pushState(window.history.state, '', url);
              }
            }
          }
        }
      });
    });
  }

  /** Highlight nav link for the section most visible under the sticky header (one-page). */
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('.site-nav__link[data-nav-section]'));
  const sectionIds = navLinks.map(a => a.getAttribute('data-nav-section')).filter(Boolean) as string[];
  const sectionEls = sectionIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];
  
  if (navLinks.length && sectionEls.length) {
    const header = document.querySelector('.header');
    const offset = header instanceof HTMLElement ? header.offsetHeight + 8 : 80;

    let currentActiveId = '';
    function setActive(navId: string) {
      if (currentActiveId === navId) return;
      currentActiveId = navId;

      navLinks.forEach((a) => {
        const match = a.getAttribute('data-nav-section') === navId;
        a.classList.toggle('site-nav__link--active', match);
        if (match) {
          a.setAttribute('aria-current', 'page');
        } else {
          a.removeAttribute('aria-current');
        }
      });

      // Update URL hash without jumping or adding to history
      // We wrap this in a check to ensure we don't interfere with Astro's back navigation
      if (window.history.replaceState && !document.documentElement.classList.contains('is-transitioning')) {
        const url = new URL(window.location.href);
        url.hash = navId === 'top' ? '' : navId;
        window.history.replaceState(window.history.state, '', url);
      }
    }

    let isScrolling = false;
    function updateSpy() {
      if (isScrolling) return;
      isScrolling = true;
      requestAnimationFrame(() => {
        const focusY = window.innerHeight * 0.35;
        let currentId = sectionEls[0]?.id || '';
        let minDistance = Infinity;

        for (const el of sectionEls) {
          const rect = el.getBoundingClientRect();
          // If the section crosses the focus line, it's active
          if (rect.top <= focusY && rect.bottom >= focusY) {
            currentId = el.id;
            break;
          }
          // Otherwise, find the one closest to the focus line
          const dist = Math.min(Math.abs(rect.top - focusY), Math.abs(rect.bottom - focusY));
          if (dist < minDistance) {
            minDistance = dist;
            currentId = el.id;
          }
        }

        // If user scrolled to the absolute bottom, highlight the last section (Contact)
        if (Math.ceil(window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight - 10) {
          currentId = sectionEls[sectionEls.length - 1].id;
        }

        if (currentId) setActive(currentId);
        isScrolling = false;
      });
    }

    window.addEventListener('scroll', updateSpy, { passive: true });
    window.addEventListener('resize', updateSpy, { passive: true });
    updateSpy();

    function syncFromHash() {
      const h = window.location.hash.slice(1);
      if (!h) return;
      if (sectionIds.includes(h)) setActive(h);
    }
    window.addEventListener('hashchange', syncFromHash);
  }
}

initHeaderScripts();
document.addEventListener('astro:after-swap', initHeaderScripts);
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--bg) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid transparent;
    padding-top: env(safe-area-inset-top, 0);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease,
      backdrop-filter 0.35s ease;
  }

  .header--scrolled {
    background: color-mix(in oklab, var(--bg) 94%, transparent);
    backdrop-filter: blur(16px);
    border-bottom-color: var(--border);
    box-shadow: 0 12px 40px color-mix(in oklab, var(--text) 5%, transparent);
  }

  .header--glitch .header__bar {
    animation: headerGlitch 0.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes headerGlitch {
    0% { filter: blur(0); transform: scale(1); }
    50% { filter: blur(4px); transform: scale(0.99); }
    100% { filter: blur(0); transform: scale(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .header--glitch .header__bar {
      animation: none;
    }
  }

  .header__shell {
    padding-left: max(var(--space-md), env(safe-area-inset-left));
    padding-right: max(var(--space-md), env(safe-area-inset-right));
  }

  .header__bar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm) var(--space-md);
    padding: var(--space-sm) 0;
    max-width: var(--max);
    margin: 0 auto;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.35rem;
    letter-spacing: 0.06em;
    color: var(--text);
    text-decoration: none;
    min-height: var(--tap-min);
    display: inline-flex;
    align-items: center;
    padding: var(--space-xs) var(--space-xs) var(--space-xs) 0;
  }

  .logo:hover {
    color: var(--text-muted);
  }

  .header__end {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-left: auto;
  }

  .site-nav {
    width: 100%;
    order: 3;
    display: none;
    padding: var(--space-md) 0 var(--space-sm);
    border-top: 1px solid var(--border);
  }

  .site-nav--open {
    display: block;
  }

  .site-nav__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-xs);
  }

  .site-nav__link {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    min-height: var(--tap-min);
    padding: var(--space-sm) var(--space-xs);
    margin-left: calc(-1 * var(--space-xs));
    margin-right: calc(-1 * var(--space-xs));
    border-radius: var(--radius);
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-nav__link:hover {
    color: var(--text);
    background: transparent;
  }

  .site-nav__link--active {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: currentColor;
    text-underline-offset: 5px;
  }

  .lang {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: var(--tap-min);
    min-height: var(--tap-min);
    padding: 0 var(--space-sm);
    border-radius: 999px;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
  }

  .lang:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .menu-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    min-height: var(--tap-min);
    min-width: var(--tap-min);
    padding: 0 var(--space-sm);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text);
    font: inherit;
    font-weight: 600;
    cursor: pointer;
  }

  .menu-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .menu-btn__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 1.35rem;
  }

  .menu-btn__bar {
    display: block;
    height: 2px;
    background: currentColor;
    border-radius: 1px;
  }

  .menu-btn__text {
    font-size: 0.95rem;
  }

  @media (min-width: 48rem) {
    .header__bar {
      flex-wrap: nowrap;
      justify-content: flex-start;
      gap: var(--space-lg);
      padding: var(--space-sm) 0;
    }

    .logo {
      flex-shrink: 0;
    }

    .site-nav {
      order: 0;
      width: auto;
      flex: 0 1 auto;
      margin-left: auto;
      display: flex !important;
      justify-content: flex-end;
      padding: 0;
      border-top: none;
    }

    .site-nav__list {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      justify-content: flex-end;
      gap: var(--space-xs) var(--space-lg);
    }

    .site-nav__link {
      min-height: var(--tap-min);
      padding: var(--space-sm) var(--space-sm);
      margin: 0;
      font-weight: 500;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .header__end {
      margin-left: 0;
      flex-shrink: 0;
    }

    .menu-btn {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-btn__bar {
      transition: none;
    }
  }
</style>
