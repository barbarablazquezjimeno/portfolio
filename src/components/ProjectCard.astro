---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  cover?: string;
  /** Visible CTA and accessible name fragment (e.g. "Ver caso") */
  viewCaseLabel: string;
  /** Optional meaningful alt when cover conveys information */
  coverAlt?: string;
}

const { href, title, description, date, cover, viewCaseLabel, coverAlt } = Astro.props;
const year = date.getFullYear();
const linkName = `${viewCaseLabel}: ${title}`;
const imageAlt = cover ? (coverAlt ?? '') : '';

/** Respects `base` in astro.config (e.g. GitHub project pages). */
function publicAssetSrc(path: string): string {
  if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('//')) return path;
  const base = import.meta.env.BASE_URL || '/';
  const normalized = base.endsWith('/') ? base : `${base}/`;
  const trimmed = path.startsWith('/') ? path.slice(1) : path;
  return `${normalized}${trimmed}`;
}

const coverSrc = cover ? publicAssetSrc(cover) : undefined;
---

<article class="card">
  <a class="card__link" href={href} aria-label={linkName}>
    <div class="card__media">
      {
        coverSrc ? (
          <img
            src={coverSrc}
            alt={imageAlt}
            loading="lazy"
            width="800"
            height="500"
            decoding="async"
          />
        ) : (
          <div class="card__placeholder" role="img" aria-hidden="true"></div>
        )
      }
    </div>
    <div class="card__body">
      <p class="card__meta">
        <time datetime={date.toISOString().slice(0, 10)}>{year}</time>
      </p>
      <h2 class="card__title">{title}</h2>
      <p class="card__desc">{description}</p>
      <span class="card__cta" aria-hidden="true">{viewCaseLabel}<span class="card__cta-icon"> →</span></span>
    </div>
  </a>
</article>

<style>
  .card {
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  @media (prefers-reduced-motion: no-preference) {
    .card {
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .card:hover,
    .card:focus-within {
      transform: translateY(-3px);
      border-color: color-mix(in oklab, var(--accent) 35%, var(--border));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card:hover,
    .card:focus-within {
      border-color: color-mix(in oklab, var(--accent) 35%, var(--border));
    }
  }

  .card__link {
    display: grid;
    grid-template-columns: 1fr;
    text-decoration: none;
    color: inherit;
    border-radius: inherit;
  }

  @media (min-width: 40rem) {
    .card__link {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    }
  }

  .card__media {
    min-height: 11.25rem;
    background: var(--accent-soft);
  }

  .card__media img {
    width: 100%;
    height: 100%;
    min-height: 11.25rem;
    object-fit: cover;
  }

  .card__placeholder {
    width: 100%;
    height: 100%;
    min-height: 11.25rem;
    background: linear-gradient(135deg, var(--accent-soft), transparent 60%);
  }

  .card__body {
    padding: var(--space-lg);
    position: relative;
    padding-bottom: calc(var(--space-lg) + 2.25rem);
  }

  .card__meta {
    margin: 0 0 var(--space-xs);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .card__title {
    margin: 0 0 var(--space-sm);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 4vw, 1.35rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .card__desc {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .card__cta {
    position: absolute;
    right: var(--space-lg);
    bottom: var(--space-lg);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
  }

  .card__cta-icon {
    font-weight: 700;
  }
</style>
