---
import { getPublicAssetUrl } from '@/lib/publicAsset';

interface Props {
  href: string;
  title: string;
  description: string;
  overline?: string;
  date?: Date;
  cover?: string;
  coverAlt?: string;
  cta?: string;
  viewCaseLabel: string;
  /** Odd index flips image/text columns on wide screens */
  index: number;
  /** Unique slug for View Transitions */
  slug: string;
}

const { href, title, description, overline, date, cover, coverAlt, cta, viewCaseLabel, index, slug } = Astro.props;

const year = date?.getFullYear();
const eyebrow = overline ?? (year != null ? String(year) : '');
const coverSrc = cover ? getPublicAssetUrl(cover) : undefined;
const imageAlt = cover ? (coverAlt ?? '') : '';
const flip = index % 2 === 1;
const linkName = `${viewCaseLabel}: ${title}`;
const ctaText = cta ?? viewCaseLabel;
---

<article class:list={['proj-exp', 'reveal', flip ? 'proj-exp--flip reveal--right' : 'reveal--left']} style={`--reveal-delay: ${Math.min(index * 120, 600)}ms`} data-project-row>
  <a class="proj-exp__link" href={href} aria-label={linkName}>
    <div class="proj-exp__media" data-tilt>
      {
        coverSrc ? (
          <img
            src={coverSrc}
            alt={imageAlt}
            loading={index === 0 ? 'eager' : 'lazy'}
            width={1200}
            height={800}
            decoding="async"
            class="proj-exp__img"
            style={`view-transition-name: cover-${slug}`}
            data-parallax
          />
        ) : (
          <div class="proj-exp__placeholder" aria-hidden="true" />
        )
      }
    </div>
    <div class="proj-exp__body">
      {eyebrow && <p class="proj-exp__eyebrow">{eyebrow}</p>}
      <h3 class="proj-exp__title">{title}</h3>
      <p class="proj-exp__desc">{description}</p>
      <span class="proj-exp__cta">
        <span class="proj-exp__cta-text">{ctaText}</span>
        <span class="proj-exp__arrow" aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>

<style>
  .proj-exp {
    margin: 0;
    border-bottom: 1px solid var(--border);
  }

  .proj-exp:last-child {
    border-bottom: none;
  }

  .proj-exp__link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.4s ease;
  }

  @media (min-width: 56rem) {
    .proj-exp__link {
      grid-template-columns: 1fr 1fr;
      min-height: min(88vh, 820px);
      align-items: stretch;
    }

    .proj-exp--flip .proj-exp__link {
      direction: rtl;
    }

    .proj-exp--flip .proj-exp__link > * {
      direction: ltr;
    }
  }

  .proj-exp__link:hover {
    background: color-mix(in oklab, var(--bg-wash) 40%, transparent);
  }

  .proj-exp__link:focus-visible {
    outline: 3px solid var(--focus-ring);
    outline-offset: -3px;
  }

  .proj-exp__media {
    position: relative;
    min-height: 16rem;
    overflow: hidden;
    background: var(--bg-wash);
    transform-style: preserve-3d;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  @media (min-width: 56rem) {
    .proj-exp__media {
      min-height: 100%;
    }
  }

  .proj-exp__img {
    width: 100%;
    height: 100%;
    min-height: 16rem;
    object-fit: cover;
    transform: scale(1.15); /* Base scale for parallax */
    transition: transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .proj-exp__link:hover .proj-exp__img {
    transform: scale(1.2);
  }

  @media (prefers-reduced-motion: reduce) {
    .proj-exp__img {
      transition: none;
      transform: scale(1);
    }
    .proj-exp__link:hover .proj-exp__img {
      transform: scale(1.02);
    }
    .proj-exp__media {
      transform: none !important;
    }
  }

  .proj-exp__placeholder {
    width: 100%;
    height: 100%;
    min-height: 16rem;
    background: linear-gradient(145deg, var(--bg-wash) 0%, color-mix(in oklab, var(--text) 8%, var(--bg-wash)) 100%);
  }

  .proj-exp__body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.25rem, 4vw, 3rem);
    gap: var(--space-md);
    max-width: 36rem;
  }

  .proj-exp__eyebrow {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .proj-exp__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2rem, 4.2vw, 3.25rem);
    font-weight: 500;
    line-height: 1.08;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .proj-exp__desc {
    margin: 0;
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--text-muted);
  }

  .proj-exp__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: var(--space-sm);
    font-family: var(--font-sans);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    width: fit-content;
  }

  .proj-exp__cta-text {
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.25s ease;
  }

  .proj-exp__link:hover .proj-exp__cta-text {
    border-bottom-color: currentColor;
  }

  .proj-exp__arrow {
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .proj-exp__link:hover .proj-exp__arrow {
    transform: translateX(5px);
  }

  @media (prefers-reduced-motion: reduce) {
    .proj-exp__arrow {
      transition: none;
    }
    .proj-exp__link:hover .proj-exp__arrow {
      transform: none;
    }
  }
</style>

<script>
  function initProjectEffects() {
    const rows = document.querySelectorAll('[data-project-row]');
    const isReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (isReduced || !rows.length) return;

    // 1. Internal Parallax (Window Effect)
    let rafId: number | null = null;
    const onScroll = () => {
      if (rafId) return;
      rafId = requestAnimationFrame(() => {
        rafId = null;
        const vh = window.innerHeight;
        rows.forEach(row => {
          const rect = row.getBoundingClientRect();
          // Check if row is in viewport
          if (rect.top < vh && rect.bottom > 0) {
            const img = row.querySelector('[data-parallax]') as HTMLElement;
            if (img) {
              // Calculate progress from -1 (bottom of screen) to 1 (top of screen)
              const progress = (rect.top - vh/2) / (vh/2 + rect.height/2);
              // Move image slightly up/down (max 8% translation)
              img.style.transform = `scale(1.15) translateY(${progress * 8}%)`;
            }
          }
        });
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // Initial trigger

    // 2. 3D Tilt Effect
    rows.forEach(row => {
      const media = row.querySelector('[data-tilt]') as HTMLElement;
      if (!media) return;
      
      row.addEventListener('mousemove', (e: Event) => {
        const mouseEvent = e as MouseEvent;
        const rect = media.getBoundingClientRect();
        
        // Calculate mouse position relative to the center of the media container
        const x = mouseEvent.clientX - rect.left;
        const y = mouseEvent.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        
        // Calculate rotation (max 6 degrees)
        const rotateX = ((y - centerY) / centerY) * -6;
        const rotateY = ((x - centerX) / centerX) * 6;
        
        media.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
      });
      
      row.addEventListener('mouseleave', () => {
        // Reset transform smoothly
        media.style.transform = `perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)`;
      });
    });

    // Cleanup before View Transitions so the image is captured cleanly
    document.addEventListener('astro:before-preparation', () => {
      window.removeEventListener('scroll', onScroll);
      rows.forEach(row => {
        const img = row.querySelector('[data-parallax]') as HTMLElement;
        const media = row.querySelector('[data-tilt]') as HTMLElement;
        if (img) img.style.transform = 'scale(1)'; // Reset for clean capture
        if (media) media.style.transform = 'none';
      });
    }, { once: true });
  }

  initProjectEffects();
  document.addEventListener('astro:after-swap', initProjectEffects);
</script>
