---
interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  cover?: string;
  viewCaseLabel: string;
  coverAlt?: string;
}

const { href, title, description, date, cover, viewCaseLabel, coverAlt } = Astro.props;
const year = date.getFullYear();
const linkName = `${viewCaseLabel}: ${title}`;
const imageAlt = cover ? (coverAlt ?? '') : '';

function publicAssetSrc(path: string): string {
  if (path.startsWith('http://') || path.startsWith('https://') || path.startsWith('//')) return path;
  const base = import.meta.env.BASE_URL || '/';
  const normalized = base.endsWith('/') ? base : `${base}/`;
  const trimmed = path.startsWith('/') ? path.slice(1) : path;
  return `${normalized}${trimmed}`;
}

const coverSrc = cover ? publicAssetSrc(cover) : undefined;
---

<article class="card-preview">
  <a class="card-preview__link" href={href} aria-label={linkName}>
    <div class="card-preview__media">
      {
        coverSrc ? (
          <img
            src={coverSrc}
            alt={imageAlt}
            loading="lazy"
            width="800"
            height="500"
            decoding="async"
          />
        ) : (
          <div class="card-preview__placeholder" role="img" aria-hidden="true"></div>
        )
      }
    </div>
    <div class="card-preview__overlay">
      <div class="card-preview__content">
        <h3 class="card-preview__title">{title}</h3>
        <p class="card-preview__desc">{description}</p>
      </div>
    </div>
  </a>
</article>

<style>
  .card-preview {
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--accent-soft);
  }

  .card-preview__link {
    display: block;
    text-decoration: none;
    color: inherit;
    border-radius: inherit;
    position: relative;
    aspect-ratio: 16 / 10;
  }

  .card-preview__media {
    width: 100%;
    height: 100%;
  }

  .card-preview__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-preview__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--accent-soft), transparent 60%);
  }

  .card-preview__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: var(--space-lg);
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.5) 60%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .card-preview:hover .card-preview__overlay,
  .card-preview:focus-within .card-preview__overlay {
    opacity: 1;
  }

  .card-preview__content {
    width: 100%;
  }

  .card-preview__title {
    margin: 0 0 var(--space-xs);
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.2;
    color: #ffffff;
  }

  .card-preview__desc {
    margin: 0;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.9);
  }
</style>
