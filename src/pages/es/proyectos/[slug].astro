---
import ProjectDetailPage from '@/components/pages/ProjectDetailPage.astro';
import { pathForLocale } from '@/i18n/ui';
import { listProjects, getProjectBySlug, projectSlugFromId } from '@/lib/projects';

export async function getStaticPaths() {
  const items = await listProjects('es');
  return items.map((item) => ({
    params: { slug: projectSlugFromId(item.id, 'es') },
  }));
}

const { slug } = Astro.params;
const entry = slug ? await getProjectBySlug('es', slug) : undefined;
if (!entry) {
  return Astro.redirect(pathForLocale('es', 'projects'));
}
---

<ProjectDetailPage lang="es" entry={entry} />
