---
import ProjectDetailPage from '@/components/pages/ProjectDetailPage.astro';
import { pathForLocale } from '@/i18n/ui';
import { listProjects, getProjectBySlug, projectSlugFromId } from '@/lib/projects';

export async function getStaticPaths() {
  const items = await listProjects('en');
  return items.map((item) => ({
    params: { slug: projectSlugFromId(item.id, 'en') },
  }));
}

const { slug } = Astro.params;
const entry = slug ? await getProjectBySlug('en', slug) : undefined;
if (!entry) {
  return Astro.redirect(pathForLocale('en', 'projects'));
}
---

<ProjectDetailPage lang="en" entry={entry} />
