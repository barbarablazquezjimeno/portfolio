# Dependencias instaladas por npm (no se suben a Git; cada persona las genera con npm install)
node_modules/

# Sitio ya “compilado” para publicar (se regenera con npm run build)
dist/

# Caché y tipos generados por Astro al trabajar
.astro/

# Variables secretas (si algún día usas claves API; no subir nunca)
.env
.env.*
!.env.example

# Archivos del sistema operativo
.DS_Store
Thumbs.db

# Logs de errores de npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editores (opcional; quita una línea si quieres compartir ajustes del equipo)
.idea/
